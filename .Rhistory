# See what gdp_constant looks like for a country you know
df %>%
filter(country == "Argentina", year == 2000) %>%
select(country, year, gdp_constant, fdi_tech)
df <- df %>%
mutate(
gdp_millions    = gdp_constant / 1e6,          # convert GDP to millions USD
fdi_tech_gdp    = (fdi_tech    / gdp_millions) * 100,   # % of GDP
fdi_finance_gdp = (fdi_finance / gdp_millions) * 100,
fdi_mining_gdp  = (fdi_mining  / gdp_millions) * 100
)
# Manual check — Argentina 2000 should give:
# (118 / 395646.07) * 100 = 0.0298%
df %>%
filter(country == "Argentina", year == 2000) %>%
select(country, year, fdi_tech, gdp_millions, fdi_tech_gdp)
vars_labels <- list(
fdi_tech_gdp       = "FDI: Science & Tech (% of GDP)",
fdi_finance_gdp    = "FDI: Finance (% of GDP)",
fdi_mining_gdp     = "FDI: Mining (% of GDP)",
IdealPointDistance = "UN Ideal Point Distance",
agree              = "UN Vote Agreement Share",
ln_gdp             = "Log GDP (Constant USD)",
ln_gdp_pc          = "Log GDP Per Capita",
ln_trade           = "Log Trade Openness"
)
rows <- list()
for (v in names(vars_labels)) {
x <- df[[v]]
rows[[v]] <- data.frame(
Variable = vars_labels[[v]],
N        = sum(!is.na(x)),
Mean     = round(mean(x, na.rm = TRUE), 4),
SD       = round(sd(x,   na.rm = TRUE), 4),
Min      = round(min(x,  na.rm = TRUE), 4),
Median   = round(median(x, na.rm = TRUE), 4),
Max      = round(max(x,  na.rm = TRUE), 4),
stringsAsFactors = FALSE
)
}
sum_table <- do.call(rbind, rows)
rownames(sum_table) <- NULL
print(sum_table)
# ── 1. Check which countries drive the Finance outliers ───────────────────────
df %>%
filter(!is.na(fdi_finance_gdp)) %>%
arrange(desc(fdi_finance_gdp)) %>%
select(country, year, fdi_finance, gdp_millions, fdi_finance_gdp) %>%
head(15)
# ── 2. Check negative FDI/GDP observations ────────────────────────────────────
cat("Negative Tech FDI/GDP:", sum(df$fdi_tech_gdp < 0, na.rm = TRUE), "obs\n")
cat("Negative Finance FDI/GDP:", sum(df$fdi_finance_gdp < 0, na.rm = TRUE), "obs\n")
cat("Negative Mining FDI/GDP:", sum(df$fdi_mining_gdp < 0, na.rm = TRUE), "obs\n")
# ── 3. Winsorize Finance at 99th percentile to handle outliers ────────────────
# This is standard practice for FDI/GDP ratios with small-economy outliers
p99_tech    <- quantile(df$fdi_tech_gdp,    0.99, na.rm = TRUE)
p99_finance <- quantile(df$fdi_finance_gdp, 0.99, na.rm = TRUE)
p99_mining  <- quantile(df$fdi_mining_gdp,  0.99, na.rm = TRUE)
p01_tech    <- quantile(df$fdi_tech_gdp,    0.01, na.rm = TRUE)
p01_finance <- quantile(df$fdi_finance_gdp, 0.01, na.rm = TRUE)
p01_mining  <- quantile(df$fdi_mining_gdp,  0.01, na.rm = TRUE)
df <- df %>%
mutate(
fdi_tech_gdp_w    = pmin(pmax(fdi_tech_gdp,    p01_tech),    p99_tech),
fdi_finance_gdp_w = pmin(pmax(fdi_finance_gdp, p01_finance), p99_finance),
fdi_mining_gdp_w  = pmin(pmax(fdi_mining_gdp,  p01_mining),  p99_mining)
)
# Check winsorized distributions
cat("\nWinsorized Tech FDI/GDP:\n");    summary(df$fdi_tech_gdp_w)
cat("\nWinsorized Finance FDI/GDP:\n"); summary(df$fdi_finance_gdp_w)
cat("\nWinsorized Mining FDI/GDP:\n");  summary(df$fdi_mining_gdp_w)
source("~/.active-rstudio-document")
