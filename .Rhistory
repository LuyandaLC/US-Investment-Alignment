cat("\n=== Main Results (IPD coefficient only) ===\n")
etable(m1, m2, m3, m4, m5, m6,
keep   = c("IdealPointDistance", "IdealPointDistance:post2008"),
digits = 4,
coefstat = "se")
source("~/.active-rstudio-document")
# ── 1. Check what is driving the positive OLS sign in Tech ───────────────────
# Is GDP per capita fully absorbing size differences?
# Try adding log GDP levels alongside per capita
m1_check <- feols(fdi_tech_gdp_w ~ IdealPointDistance + ln_gdp + ln_gdp_pc + ln_trade,
data = df_main, vcov = "hetero")
cat("=== m1 with both GDP level and per capita ===\n")
etable(m1, m1_check, keep = "IdealPointDistance", digits = 4)
# ── 2. Check remaining Finance outliers after Bermuda drop ───────────────────
cat("\n=== Top 10 Finance FDI/GDP after Bermuda drop ===\n")
df_finance %>%
filter(!is.na(fdi_finance_gdp)) %>%
arrange(desc(fdi_finance_gdp)) %>%
select(country, year, fdi_finance_gdp, fdi_finance_gdp_w) %>%
head(10) %>%
print()
# ── 3. Check correlation between IPD and GDP per capita ──────────────────────
# If rich countries are also more aligned, OLS picks up size not alignment
cat("\n=== Correlation: IPD vs controls ===\n")
df_main %>%
select(IdealPointDistance, ln_gdp, ln_gdp_pc, ln_trade) %>%
cor(use = "pairwise.complete.obs") %>%
round(3) %>%
print()
# ── 4. Run Finance with Country FE to see if sign flips ──────────────────────
m4_fe <- feols(fdi_finance_gdp_w ~ IdealPointDistance + ln_gdp_pc + ln_trade | country,
data = df_finance, vcov = ~country)
cat("\n=== Finance with Country FE ===\n")
etable(m4, m4_fe, keep = "IdealPointDistance", digits = 4)
# ── 5. Run Mining with Country FE ─────────────────────────────────────────────
m5_fe <- feols(fdi_mining_gdp_w ~ IdealPointDistance + ln_gdp_pc + ln_trade | country,
data = df, vcov = ~country)
cat("\n=== Mining with Country FE ===\n")
etable(m5, m5_fe, keep = "IdealPointDistance", digits = 4)
